# Super-Key 环境变量配置
# 复制此文件为 .env 并修改为你的实际值

# 服务配置
SUPER_KEY_HOST=0.0.0.0
SUPER_KEY_PORT=8000
SUPER_KEY_PUBLIC_URL=

# API Token（必须修改为强随机值！）
SUPER_KEY_API_TOKEN=sk-your-strong-random-api-token-here

# 数据库（SQLite 不可用于 Vercel 等 Serverless 环境）
SUPER_KEY_DATABASE_URL=sqlite+aiosqlite:///./data/super_key.db

# 加密密钥（必须修改为 32 字节随机字符串！）
SUPER_KEY_ENCRYPTION_KEY=change-me-to-32-byte-random-str!

# 管理员 Token（必须修改为强随机值！）
ADMIN_TOKEN=change-me-to-strong-random-token

# 默认管理员密码（首次启动时创建管理员，留空则自动生成随机密码并打印到日志）
SUPER_KEY_DEFAULT_ADMIN_PASSWORD=

# 日志级别
SUPER_KEY_LOG_LEVEL=INFO
